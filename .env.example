# ============================================================================
# japan-professor-match — deployment contract
# Copy to `.env` and fill in. The snapshot-based quickstart needs NO API keys to
# SEARCH (vectors are pre-built); keys are only needed to embed NEW queries or to
# rebuild the index from raw data. See README for the two paths.
# ============================================================================

# ---- Qdrant (vector DB) ----------------------------------------------------
# docker-compose brings up a local Qdrant at this URL by default.
QDRANT_URL=http://qdrant:6333
QDRANT_COLLECTION=professors
QDRANT_TIMEOUT=30

# ---- Embedding provider ----------------------------------------------------
# EMBEDDING_PROVIDER: dashscope (default, matches production) | openai
EMBEDDING_PROVIDER=dashscope
# DashScope text-embedding-v4 (1024-d). Key is shared with the Qwen LLM account.
EMBEDDING_API_URL=https://dashscope.aliyuncs.com/api/v1/services/embeddings/text-embedding/text-embedding
EMBEDDING_API_KEY=
EMBEDDING_MODEL=text-embedding-v4
EMBEDDING_DIM=1024
# OpenAI alternative (text-embedding-3-small is 1536-d -> set EMBEDDING_DIM and rebuild index).
OPENAI_API_KEY=
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# ---- LLM provider (keyword expansion; optional, degrades gracefully) -------
# LLM_PROVIDER: dashscope (Qwen) | openai | none  (none -> skip expansion, search raw input)
LLM_PROVIDER=dashscope
QWEN_API_KEY=
QWEN_MODEL=qwen-plus
OPENAI_LLM_MODEL=gpt-4o-mini

# ---- Service ---------------------------------------------------------------
# DEMO_MODE=true disables anything stateful and is what the public preview runs.
DEMO_MODE=false
# Optional shared secret to gate the /admin config endpoints of the web terminal.
ADMIN_TOKEN=
